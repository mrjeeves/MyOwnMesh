{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyOwnMesh",
  "identifier": "run.myownmesh.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MyOwnMesh",
        "width": 1100,
        "height": 720,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
